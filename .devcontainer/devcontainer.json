{
  "name": "cmd-mcp-framework (Linux)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "cmake.generator": "Ninja",
        "cmake.configureOnOpen": true
      }
    }
  },
  "mounts": [
    "source=${localEnv:DEVCONTAINER_MOUNT_PATH},target=/media/dev-mount,type=bind"
  ],
  "forwardPorts": [4173, 5432, 5433, 6543],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "containerEnv": {
    "VCPKG_ROOT": "/media/dev-mount/vcpkg",
    "GIT_AUTHOR_NAME": "Amit Kshirsagar",
    "GIT_AUTHOR_EMAIL": "amit.kshirsagar.13@gmail.com",
    "GIT_COMMITTER_NAME": "Amit Kshirsagar",
    "GIT_COMMITTER_EMAIL": "amit.kshirsagar.13@gmail.com"
  },
  "remoteUser": "vscode"
}